# SJTU-hosted OpenAI-compatible model service.
DPSK_API_BASE=https://models.sjtu.edu.cn/api/v1
DPSK_API_KEY=
DPSK_MODEL=deepseek-chat
DPSK_TIMEOUT_SECONDS=60
DPSK_ALLOWED_BASE_HOSTS=models.sjtu.edu.cn

# Shuiyuan Discourse API. Prefer completing the read-only authorization flow in the Web UI.
SHUIYUAN_BASE_URL=https://shuiyuan.sjtu.edu.cn
SHUIYUAN_ALLOWED_BASE_HOSTS=shuiyuan.sjtu.edu.cn

# Optional CLI-only credentials. Never commit real values.
SHUIYUAN_USER_API_CLIENT_ID=
SHUIYUAN_USER_API_KEY=
